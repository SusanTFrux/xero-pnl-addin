<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  manifest.xml
  ============
  This file tells Excel everything it needs to know about our add-in:
  where to find it, what it's called, and what icon to show.

  IMPORTANT — before sideloading this, replace every instance of
  YOUR-NETLIFY-APP with your actual Netlify app name, e.g.
  https://xero-pnl.netlify.app
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">

  <!-- A unique ID for this add-in — generate a fresh one at guidgenerator.com -->
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Your Organisation</ProviderName>
  <DefaultLocale>en-NZ</DefaultLocale>
  <DisplayName DefaultValue="Xero P&amp;L Refresher"/>
  <Description DefaultValue="Fetch live P&amp;L data from Xero into your spreadsheet"/>

  <!-- Icons — replace with your own if you like -->
  <IconUrl DefaultValue="https://YOUR-NETLIFY-APP.netlify.app/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://YOUR-NETLIFY-APP.netlify.app/assets/icon-80.png"/>
  <SupportUrl DefaultValue="https://YOUR-NETLIFY-APP.netlify.app"/>

  <!-- Which Office apps this add-in works in -->
  <Hosts>
    <Host Name="Workbook"/>
  </Hosts>

  <!-- Minimum Excel version required -->
  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="ExcelApi" MinVersion="1.7"/>
    </Sets>
  </Requirements>

  <!-- Default task pane location (used by older Excel versions) -->
  <DefaultSettings>
    <SourceLocation DefaultValue="https://YOUR-NETLIFY-APP.netlify.app/taskpane.html"/>
  </DefaultSettings>

  <!-- Permissions — ReadWriteDocument lets us read and write cells -->
  <Permissions>ReadWriteDocument</Permissions>

  <!-- Modern add-in overrides — adds the ribbon button -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Workbook">
        <DesktopFormFactor>

          <!-- The button that appears in the Excel ribbon -->
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="xero.group">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="xero.button">
                  <Label resid="ButtonLabel"/>
                  <Supertip>
                    <Title resid="ButtonLabel"/>
                    <Description resid="ButtonTip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon16"/>
                    <bt:Image size="32" resid="Icon32"/>
                    <bt:Image size="80" resid="Icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>xero.taskpane</TaskpaneId>
                    <SourceLocation resid="TaskpaneUrl"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

          <!-- The task pane itself -->
          <RequestedHeight>550</RequestedHeight>
          <TaskpaneApp>
            <SupportedHosts>
              <Host Name="Workbook"/>
            </SupportedHosts>
          </TaskpaneApp>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <!-- String resources — all the text labels used above -->
    <Resources>
      <bt:Images>
        <bt:Image id="Icon16" DefaultValue="https://YOUR-NETLIFY-APP.netlify.app/assets/icon-16.png"/>
        <bt:Image id="Icon32" DefaultValue="https://YOUR-NETLIFY-APP.netlify.app/assets/icon-32.png"/>
        <bt:Image id="Icon80" DefaultValue="https://YOUR-NETLIFY-APP.netlify.app/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="TaskpaneUrl" DefaultValue="https://YOUR-NETLIFY-APP.netlify.app/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Xero"/>
        <bt:String id="ButtonLabel" DefaultValue="Refresh P&amp;L"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="ButtonTip" DefaultValue="Open the Xero P&amp;L Refresher to pull live data into this spreadsheet"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
